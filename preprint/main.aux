\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Main local-ESS experiment. The model is calibrated by construction, so the true worst-group error is zero. Reported worst-group values are therefore false alarms created by weighted noise.}}{11}{table.caption.7}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:local-ess-main}{{1}{11}{Main local-ESS experiment. The model is calibrated by construction, so the true worst-group error is zero. Reported worst-group values are therefore false alarms created by weighted noise}{table.caption.7}{}}
