\@writefile{toc}{\contentsline {paragraph}{Why the experiment matters.}{11}{section*.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Left: global ESS declines with shift severity, but the lower tail of local ESS collapses much faster. Right: false worst-group alarms become common as shift grows, even though the model is calibrated by construction. Logistic density-ratio weights show the same qualitative pattern.}}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:local-ess-main}{{1}{12}{Left: global ESS declines with shift severity, but the lower tail of local ESS collapses much faster. Right: false worst-group alarms become common as shift grows, even though the model is calibrated by construction. Logistic density-ratio weights show the same qualitative pattern}{figure.caption.9}{}}
\newlabel{fig:local-ess-main@cref}{{[figure][1][]1}{[1][11][]12}{}{}{}}
